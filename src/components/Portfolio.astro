---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import type { Translations } from '../i18n/types';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<Layout title={t.meta.title} description={t.meta.description} lang={t.lang} altLang={t.altLang} altPath={t.altPath}>
  <!-- NAV -->
  <header>
    <nav>
      <span class="logo"><span class="accent">PP</span></span>
      <button class="hamburger" aria-label={t.nav.toggleMenu} aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <ul>
        <li><a href="#about">{t.nav.about}</a></li>
        <li><a href="#stack">{t.nav.stack}</a></li>
        <li><a href="#experience">{t.nav.experience}</a></li>
        <li><a href="#projects">{t.nav.projects}</a></li>
        <li><a href="#approach">{t.nav.approach}</a></li>
        <li><a href="#education">{t.nav.education}</a></li>
      </ul>
      <div class="lang-switch mono">
        <a href="/" class={t.lang === 'en' ? 'active' : ''}>EN</a>
        <span class="muted">/</span>
        <a href="/pl/" class={t.lang === 'pl' ? 'active' : ''}>PL</a>
      </div>
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section id="about" class="hero">
      <div class="container">
        <p class="hero-greeting"><span class="mono muted">{t.hero.greeting}</span></p>
        <h1>{t.hero.name}</h1>
        <h2>{t.hero.role}</h2>
        <p class="hero-bio" set:html={t.hero.bio} />
        <div class="hero-links">
          <a href="https://github.com/pawelel" target="_blank" rel="noopener" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/pawe%C5%82-przytu%C5%82a-61285b102/" target="_blank" rel="noopener" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.73V1.73C24 .77 23.2 0 22.23 0zM7.06 20.45H3.56V9h3.5v11.45zM5.31 7.43h-.02c-1.17 0-1.93-.8-1.93-1.8 0-1.02.78-1.8 1.97-1.8 1.17 0 1.91.78 1.93 1.8 0 1 .76 1.8-1.95 1.8zM20.45 20.45h-3.5v-5.61c0-1.41-.5-2.37-1.76-2.37-.96 0-1.53.64-1.78 1.27-.09.22-.12.53-.12.84v5.87H9.8s.05-10.37 0-11.45h3.49v1.62c.46-.72 1.28-1.73 3.12-1.73 2.28 0 3.99 1.49 3.99 4.71v6.85z"/></svg>
            LinkedIn
          </a>
        </div>
        <div class="scroll-hint">
          <span class="mono muted">{t.hero.scrollDown}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
        </div>
      </div>
    </section>

    <!-- TECH STACK -->
    <section id="stack">
      <div class="container">
        <h3 class="section-label"><span class="mono accent">01.</span> {t.sections.stack.label}</h3>
        <h2 class="section-title">{t.sections.stack.title}</h2>
        <div class="stack-grid">
          {t.techStack.map((group) => (
            <div class="stack-group">
              <p class="stack-category muted mono">{group.category}</p>
              <div class="stack-items">
                {group.items.map((item) => (
                  <span class="tag">
                    <Icon name={item.icon} />
                    {item.name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience">
      <div class="container">
        <h3 class="section-label"><span class="mono accent">02.</span> {t.sections.experience.label}</h3>
        <h2 class="section-title">{t.sections.experience.title}</h2>
        <div class="timeline">
          {t.experienceList.map((job, i) => (
            <div class="timeline-item">
              <div class="timeline-line-wrapper">
                <div class="timeline-dot"></div>
                {i < t.experienceList.length - 1 && <div class="timeline-line"></div>}
              </div>
              <div class="timeline-content">
                <div class="job-header">
                  <div>
                    <h3 class="job-role">{job.role}</h3>
                    <p class="job-company">{job.company}</p>
                  </div>
                  <span class="job-period mono">{job.period}</span>
                </div>
                <ul class="job-items">
                  {job.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section id="projects">
      <div class="container">
        <h3 class="section-label"><span class="mono accent">03.</span> {t.sections.projects.label}</h3>
        <h2 class="section-title">{t.sections.projects.title}</h2>
        <div class="projects-list">
          {t.projectsList.map((project, i) => (
            <article class="project-card">
              <div class="project-header">
                <span class="project-number mono muted">0{i + 1}</span>
                <h3 class="project-title">{project.title}</h3>
                <span class={`project-type mono ${project.type === 'Commercial' || project.type === 'Komercyjny' ? 'type-commercial' : project.type === 'Open Source' ? 'type-opensource' : 'type-personal'}`}>{project.type}</span>
                {project.link && (
                  <a href={project.link} target="_blank" rel="noopener" class="project-link" title={t.projects.viewOnGithub}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  </a>
                )}
              </div>
              <p class="project-desc">{project.description}</p>
              {project.criteria && (
                <div class="project-criteria">
                  <span class="criteria-label">{t.projects.criteriaLabel}</span>
                  {project.criteria.map((c) => (
                    <span class="criterion">{c}</span>
                  ))}
                </div>
              )}
              <div class="project-highlights">
                {project.highlights.map((h) => (
                  <span class="highlight">{h}</span>
                ))}
              </div>
              <div class="project-stack">
                {project.stack.map((tech) => (
                  <span class="tag tag-sm">{tech}</span>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- HOW I WORK -->
    <section id="approach">
      <div class="container">
        <h3 class="section-label"><span class="mono accent">04.</span> {t.sections.approach.label}</h3>
        <h2 class="section-title">{t.sections.approach.title}</h2>

        <p class="subsection-label">{t.approach.withinSprint}</p>
        <div class="sprint-phases">
          {t.approach.phases.map((phase) => (
            <div class="phase">
              <p class="phase-name">{phase.name}</p>
              <ul>
                {phase.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <p class="subsection-label" style="margin-top: 56px;">{t.approach.beyondSprint}</p>
        <div class="approach-grid">
          {t.approach.items.map((item) => (
            <div class="approach-item">
              <p class="approach-title">{item.title}</p>
              <p class="approach-desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- EDUCATION -->
    <section id="education">
      <div class="container">
        <h3 class="section-label"><span class="mono accent">05.</span> {t.sections.education.label}</h3>
        <h2 class="section-title">{t.sections.education.title}</h2>
        <div class="edu-card">
          <div class="edu-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <div>
            <h3 class="edu-degree">{t.education.degree}</h3>
            <p class="edu-school">{t.education.school}</p>
            <p class="mono muted edu-year">{t.education.period}</p>
          </div>
        </div>
        <div class="interests">
          <h4 class="interests-title muted">{t.education.beyondWork}</h4>
          <div class="interests-items">
            <div class="interest-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              <span>{t.education.interests[0]}</span>
            </div>
            <div class="interest-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              <span>{t.education.interests[1]}</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p class="mono muted">{t.footer} <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> · <a href="https://github.com/pawelel" target="_blank" rel="noopener">github.com/pawelel</a></p>
    </div>
  </footer>
</Layout>

<style>
  .container { max-width: 860px; margin: 0 auto; padding: 0 24px; }
  .mono { font-family: var(--mono); font-size: 0.85em; }
  .muted { color: var(--muted); }
  .accent { color: var(--accent); }

  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  nav {
    max-width: 860px; margin: 0 auto; padding: 0 24px;
    height: 56px; display: flex; align-items: center; justify-content: space-between;
    position: relative;
  }
  .logo { font-family: var(--mono); font-size: 1rem; font-weight: 700; letter-spacing: 2px; }
  nav ul { list-style: none; display: flex; gap: 28px; }
  nav ul a { color: var(--muted); font-size: 0.875rem; transition: color 0.2s; }
  nav ul a:hover { color: var(--text); text-decoration: none; }
  nav ul a:focus { outline: none; }
  nav ul a:focus-visible { outline: 1px solid var(--accent); border-radius: 2px; }
  .hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; background: none; border: none; cursor: pointer; padding: 6px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: var(--text); border-radius: 2px; transition: transform 0.22s, opacity 0.22s; }
  nav.open .hamburger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  nav.open .hamburger span:nth-child(2) { opacity: 0; }
  nav.open .hamburger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .lang-switch { display: flex; align-items: center; gap: 4px; font-size: 0.8rem; }
  .lang-switch a { color: var(--muted); transition: color 0.2s; }
  .lang-switch a:hover { color: var(--text); text-decoration: none; }
  .lang-switch a.active { color: var(--accent); font-weight: 600; }

  section { padding: 96px 0; }
  section:first-child { padding-top: 0; }

  .section-label { font-size: 0.875rem; color: var(--muted); margin-bottom: 8px; }
  .subsection-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 20px; }
  .sprint-phases { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .phase { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
  .phase:last-child { border-right: none; }
  .phase-num { font-size: 0.75rem; color: var(--accent); margin-bottom: 8px; letter-spacing: 0.05em; }
  .phase-name { font-weight: 600; font-size: 0.95rem; margin-bottom: 14px; color: var(--accent); }
  .phase ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
  .phase ul li { font-size: 0.9rem; color: var(--muted); padding-left: 16px; position: relative; line-height: 1.4; }
  .phase ul li::before { content: '\2192'; position: absolute; left: 0; color: var(--accent); font-size: 0.8em; top: 1px; }
  .approach-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 8px; }
  .approach-item { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px; }
  .approach-title { font-weight: 600; color: var(--accent); margin-bottom: 10px; font-size: 0.95rem; }
  .approach-desc { color: var(--muted); font-size: 0.875rem; line-height: 1.65; margin: 0; }
  .section-title { font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 48px; }

  .hero {
    min-height: 100vh; display: flex; align-items: center;
    padding-top: 80px;
    border-bottom: 1px solid var(--border);
  }
  .hero-greeting { margin-bottom: 12px; }
  .hero h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700; line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  .hero h2 {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    font-weight: 400; color: var(--accent);
    margin-bottom: 24px;
  }
  .hero-bio {
    max-width: 560px; color: var(--muted);
    font-size: 1.05rem; line-height: 1.75;
    margin-bottom: 36px;
  }
  .hero-bio :global(strong) { color: var(--text); font-weight: 500; }
  .hero-links { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 64px; }

  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: var(--radius);
    font-size: 0.875rem; font-weight: 500; transition: all 0.2s;
    cursor: pointer; border: 1px solid transparent;
  }
  .btn:hover { text-decoration: none; transform: translateY(-1px); }
  .btn-primary { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  .btn-primary:hover { background: #67e8f9; border-color: #67e8f9; }
  .btn-outline { background: transparent; color: var(--text); border-color: var(--border); }
  .btn-outline:hover { border-color: var(--accent); color: var(--accent); }

  .scroll-hint {
    display: flex; align-items: center; gap: 8px; color: var(--muted);
    font-size: 0.8rem;
    animation: bounce 2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  #stack { border-bottom: 1px solid var(--border); }
  .stack-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 32px; }
  .stack-category { font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .stack-items { display: flex; flex-wrap: wrap; gap: 8px; }

  .tag {
    display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 4px; font-size: 0.8rem; color: var(--text);
    transition: border-color 0.2s;
  }
  .tag :global(svg) { width: 14px; height: 14px; }
  .tag:hover { border-color: var(--accent); color: var(--accent); }
  .tag-sm { font-size: 0.75rem; padding: 3px 10px; }

  #projects { border-bottom: 1px solid var(--border); }
  .projects-list { display: flex; flex-direction: column; gap: 32px; }

  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px; padding: 28px 32px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .project-card:hover { border-color: var(--accent); transform: translateY(-2px); }

  .project-header { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
  .project-number { font-size: 0.75rem; letter-spacing: 0.1em; }
  .project-title { font-size: 1.15rem; font-weight: 600; flex: 1; }
  .project-type { font-size: 0.7rem; letter-spacing: 0.05em; padding: 2px 8px; border-radius: 4px; white-space: nowrap; }
  .type-commercial { background: rgba(34,211,238,0.08); color: var(--accent); border: 1px solid rgba(34,211,238,0.2); }
  .type-personal { background: var(--surface); color: var(--muted); border: 1px solid var(--border); }
  .type-opensource { background: rgba(74,222,128,0.08); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .project-link { color: var(--muted); display: flex; align-items: center; transition: color 0.2s; }
  .project-link:hover { color: var(--accent); }
  .project-desc { color: var(--muted); line-height: 1.7; margin-bottom: 16px; font-size: 0.95rem; }
  .project-criteria { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; margin-bottom: 12px; }
  .criteria-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-right: 2px; }
  .criterion { font-family: var(--font-mono); font-size: 0.75rem; white-space: nowrap; background: rgba(34,211,238,0.08); color: var(--accent); border: 1px solid rgba(34,211,238,0.2); border-radius: 4px; padding: 2px 7px; }
  .project-highlights { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .highlight {
    display: inline-block; padding: 3px 10px;
    background: var(--accent-dim); border: 1px solid rgba(34,211,238,0.3);
    border-radius: 4px; font-size: 0.75rem; color: var(--accent);
    font-family: var(--mono);
  }
  .project-stack { display: flex; flex-wrap: wrap; gap: 6px; }

  #experience { border-bottom: 1px solid var(--border); }
  .timeline { position: relative; display: flex; flex-direction: column; gap: 0; }
  .timeline-item { display: flex; gap: 20px; }
  .timeline-line-wrapper { display: flex; flex-direction: column; align-items: center; }
  .timeline-dot {
    width: 10px; height: 10px; min-width: 10px;
    background: var(--accent); border-radius: 50%;
    margin-top: 6px;
  }
  .timeline-line { flex: 1; width: 2px; background: var(--border); min-height: 20px; }

  .timeline-content { padding-bottom: 40px; flex: 1; }
  .job-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 8px; margin-bottom: 14px;
  }
  .job-role { font-size: 1.05rem; font-weight: 600; margin-bottom: 2px; }
  .job-company { color: var(--accent); font-size: 0.9rem; }
  .job-period { color: var(--muted); font-size: 0.8rem; white-space: nowrap; }
  .job-items { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .job-items li {
    color: var(--muted); font-size: 0.9rem; padding-left: 16px; position: relative;
  }
  .job-items li::before {
    content: '\2192'; position: absolute; left: 0; color: var(--accent); font-size: 0.8em;
  }

  #education { border-bottom: 1px solid var(--border); }
  .edu-card {
    display: flex; align-items: flex-start; gap: 20px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: 24px 28px; margin-bottom: 40px;
  }
  .edu-icon {
    width: 48px; height: 48px; min-width: 48px;
    background: var(--accent-dim); border: 1px solid rgba(34,211,238,0.3);
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .edu-degree { font-size: 1.05rem; font-weight: 600; margin-bottom: 4px; }
  .edu-school { color: var(--muted); font-size: 0.9rem; margin-bottom: 4px; }
  .edu-year { font-size: 0.8rem; }

  .interests-title { font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px; }
  .interests-items { display: flex; flex-direction: column; gap: 12px; }
  .interest-item { display: flex; align-items: center; gap: 12px; color: var(--muted); font-size: 0.9rem; }
  .interest-item svg { color: var(--accent); flex-shrink: 0; }

  footer {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }
  footer .container { display: flex; justify-content: center; }
  footer p { font-size: 0.8rem; }

  @media (max-width: 600px) {
    .hamburger { display: flex; }
    nav ul {
      display: none; flex-direction: column; gap: 0;
      position: absolute; top: 56px; left: 0; right: 0;
      background: var(--bg); border-bottom: 1px solid var(--border);
      padding: 8px 0 16px; z-index: 99;
    }
    nav ul li { border-bottom: 1px solid var(--border); }
    nav ul li:last-child { border-bottom: none; }
    nav ul a { display: block; padding: 14px 24px; font-size: 0.9375rem; color: var(--text); }
    nav.open ul { display: flex; }
    .stack-grid { grid-template-columns: 1fr; gap: 24px; }
    .approach-grid { grid-template-columns: 1fr; gap: 16px; }
    .sprint-phases { grid-template-columns: 1fr 1fr; }
    .phase { border-right: none; border-bottom: none; }
    .project-card { padding: 20px; }
    .job-header { flex-direction: column; }
  }
</style>

<script>
  const nav = document.querySelector('nav');
  const btn = document.querySelector('.hamburger');
  if (nav && btn) {
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      nav.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }));
  }
</script>
