    nav ul li:last-child { border-bottom: none; }
    nav ul a { display: block; padding: 14px 24px; font-size: 0.9375rem; color: var(--text); }
    nav.open ul { display: flex; }
    .stack-grid { grid-template-columns: 1fr; gap: 24px; }
    .approach-grid { grid-template-columns: 1fr; gap: 16px; }
    .sprint-phases { grid-template-columns: 1fr 1fr; }
